{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "TCG Action Schema v0.1 (agent contract)",
  "type": "object",
  "required": ["type"],
  "properties": {
    "type": {
      "type": "string",
      "enum": ["play_card", "attack", "end_phase", "resolve_stack", "concede"]
    },
    "actorId": {
      "type": "string",
      "description": "optional for local simulation; server runtime manages actorId from auth session"
    },
    "payload": {
      "type": "object",
      "properties": {
        "handIndex": { "type": "integer", "minimum": 0 },
        "zoneIndex": { "type": "integer", "minimum": 0 },
        "attackerId": { "type": "string" },
        "targetUnitId": { "type": "string" },
        "targetAgentId": { "type": "string" }
      },
      "additionalProperties": true
    }
  },
  "additionalProperties": false
}
